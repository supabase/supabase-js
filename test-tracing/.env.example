# Copy to .env and fill in your values
# Staging uses *.supabase.red, prod uses *.supabase.co

STAGING_URL=https://<project-id>.supabase.red
STAGING_KEY=<staging-anon-or-publishable-key>

PROD_URL=https://<project-id>.supabase.co
PROD_KEY=<prod-anon-or-publishable-key>

# Any existing table (defaults to "test")
TABLE=test
