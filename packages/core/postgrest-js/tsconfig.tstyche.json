{
  "include": ["src", "test"],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "outDir": "dist/cjs",
    "rootDir": ".",
    "sourceMap": true,
    "target": "ES2020",
    "lib": ["ES2022"],

    "strict": true,

    "esModuleInterop": true,
    "moduleResolution": "Node",

    "forceConsistentCasingInFileNames": true,
    "stripInternal": true,
    "noImplicitOverride": false,
    "isolatedModules": false,
    "types": ["jest", "node"],
    "skipLibCheck": true
  }
}
