# This sub-app installs @supabase/supabase-js from pkg.pr.new URLs to simulate
# real consumer installs of a preview build. The published manifest in the
# tarball references sibling packages (@supabase/auth-js, /realtime-js, etc.)
# by URL, which the root workspace's blockExoticSubdeps rule rejects. Disable
# the rule locally so CI can install this standalone app.
block-exotic-subdeps=false
