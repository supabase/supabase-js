{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/elements": "^2.0.0",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "https://pkg.pr.new/@supabase/supabase-js@{COMMIT_HASH}",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.0",
    "expo-constants": "~18.0.0",
    "expo-font": "~14.0.0",
    "expo-haptics": "~15.0.0",
    "expo-image": "~3.0.0",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-symbols": "~1.0.0",
    "expo-system-ui": "~6.0.0",
    "expo-web-browser": "~15.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.0.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.0.0",
    "@types/react": "~19.1.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3",
    "ws": "^8.18.0"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(isows|@supabase|@react-native|react-native|expo-modules-core|expo)/)"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
