{
  "name": "@supabase/realtime-js",
  "targets": {
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cp .env.local.ci .env.local || true",
          "pnpm exec playwright install chromium",
          "pnpm exec playwright test"
        ],
        "cwd": "{projectRoot}/example",
        "parallel": false
      },
      "dependsOn": [
        "build",
        {
          "projects": ["supabase-js"],
          "target": "build"
        }
      ],
      "metadata": {
        "description": "Run Playwright E2E tests against the realtime-js chat example app"
      }
    }
  }
}
